# Copy to .env and fill in values. NEVER commit .env to git.

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev: postgres://user:pass@localhost:5432/research_platform
# Production: pulled from Secrets Manager via DB_SECRET_ARN
DATABASE_URL=postgres://platform_app:change_in_production@localhost:5432/research_platform
DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:research-data-platform/db-credentials

# ─── Auth0 ───────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.research-platform.io

# ─── Infrastructure (populated by Terraform outputs) ─────────────────────────
S3_BUCKET=research-data-platform-raw-data
ECS_CLUSTER=research-data-platform-processing
ECS_TASK_DEF=research-data-platform-decoder
